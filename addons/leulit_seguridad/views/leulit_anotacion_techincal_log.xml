<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record model="ir.ui.view" id="leulit_20260401_1013_tree">
            <field name="name">leulit_20260401_1013_tree</field>
            <field name="model">leulit.anotacion_technical_log</field>
            <field name="arch" type="xml">
                <tree string="Anotaciones Technical Log">
                    <field name="codigo" />
                    <field name="estado" column_invisible="1"/>
                    <field name="anotacion" />
                    <field name="fecha" />
                    <field name="helicoptero_id" />
                </tree>
            </field>
        </record>


        <record model="ir.ui.view" id="leulit_20260401_1013_form">
            <field name="name">leulit_20260401_1013_form</field>
            <field name="model">leulit.anotacion_technical_log</field>
            <field name="arch" type="xml">
                <form string="Anotación Technical Log">
                    <header>
                        <button name="wizard_cerrar" type="object" string="Cerrar" invisible="estado in ['closed']"  class="oe_right oe_highlight"/>
                        <button name="wizard_activar" type="object" string="Activar" invisible="estado in ['active', 'closed']"  class="oe_right oe_highlight"/>
                        <field name="estado" widget="statusbar" class="oe_right"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="codigo" readonly="1"/>
                        </group>
                        <group>
                        <group string="Report">
                            <group>
                                <field name="fecha" readonly="estado in ['active', 'closed']"/>
                                <label for="informado_por" string="Who"/>
                                <div class="o_row">
                                    <field name="informado_por" nolabel="1" options="{'no_create': True, 'no_open': True}"/>
                                    <span>(</span>
                                    <field name="rol_informa" nolabel="1" readonly="estado in ['active', 'closed']"/>
                                    <span>)</span>
                                </div>
                            </group>
                            <group>
                                <field name="helicoptero_id" readonly="estado in ['active', 'closed']" options="{'no_create': True, 'no_open': True}"/>
                                <field name="lugar" readonly="estado in ['active', 'closed']"/>
                            </group>
                            <group colspan="2">
                                <field name="anotacion" readonly="estado in ['active', 'closed']" colspan="2"/>
                            </group>
                        </group>
                        <group string="Close">
                            <group>
                                <field name="fecha_cierre" readonly="estado == 'closed'"/>
                                <label for="cerrado_por" string="Who"/>
                                <div class="o_row">
                                    <field name="cerrado_por" nolabel="1"/>
                                    <span>(</span>
                                    <field name="rol_close" nolabel="1" readonly="((estado in ['active', 'closed']))"/>
                                    <span>)</span>
                                </div>
                            </group>
                            <group>
                                <field name="lugar_cierre" readonly="estado == 'closed'"/>
                                <field name="accion_cierre" readonly="estado == 'closed'"/>
                            </group>
                        </group>
                        </group>
                        
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>


        <record model="ir.actions.act_window" id="leulit_20260401_1013_action">
            <field name="name">Anotaciones Technical Log</field>
            <field name="res_model">leulit.anotacion_technical_log</field>
            <field name="view_mode">tree,form</field>
        </record>


        <record id="leulit_anotacion_technical_log_mail_camo_estado" model="mail.template">
            <field name="name">Helipistas mail informa estado anotación technical log CAMO</field>
            <field name="model_id" ref="model_leulit_anotacion_technical_log" />
            <field name="email_from">erp@helipistas.com</field>
            <field name="email_to">albert@icarus-manteniment.com,otecnica@helipistas.com</field>
            <field name="subject">{{ ctx.get('subject') }}</field>
            <field name="auto_delete" eval="True" />
            <field name="body_html" type="html">
                <table border="0" cellpadding="0" cellspacing="0">
                    <tr>
                        <td>
                            Código:
                        </td>
                        <td>
                            <t t-out="object.codigo"/>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Estado:
                        </td>
                        <td>
                            <t t-out="object.estado"/>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Máquina:
                        </td>
                        <td>
                            <t t-out="object.helicoptero_id.name"/>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Anotación:
                        </td>
                        <td>
                            <t t-out="object.anotacion"/><br/>
                        </td>
                    </tr>
                </table>
            </field>
        </record>

    </data>
</odoo>