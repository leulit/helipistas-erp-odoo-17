<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record model="ir.ui.view" id="leulit_20260401_1013_tree">
            <field name="name">leulit_20260401_1013_tree</field>
            <field name="model">leulit.anotacion_technical_log</field>
            <field name="arch" type="xml">
                <tree string="Anotaciones Log Book">
                    <field name="codigo" />
                    <field name="estado" column_invisible="1"/>
                    <field name="anotacion" />
                    <field name="fecha" />
                    <field name="helicoptero_id" />
                </tree>
            </field>
        </record>


        <record model="ir.ui.view" id="leulit_20260401_1013_form">
            <field name="name">leulit_20260401_1013_form</field>
            <field name="model">leulit.anotacion_technical_log</field>
            <field name="arch" type="xml">
                <form string="Anotación Log Book">
                    <header>
                        <button name="wizard_close" type="object" string="Cerrar" invisible="estado in ['closed']"  class="oe_right oe_highlight"/>
                        <button name="wizard_pending" type="object" string="En Pendiente" invisible="estado not in ['edition']"  class="oe_right oe_highlight"/>
                        <field name="estado" widget="statusbar" class="oe_right"/>
                    </header>
                    <sheet>
                        <h4>Certifies that the work specified except as otherwise specified was carried out in accordance with Part 145 and in respect to that work the aircraft is considered ready for Release to Service</h4>
                        <h4>If you have mechanical issues contact with: Helipistas Operaciones or CAMO. Telf: 0034 937 304 911</h4>
                        <group>
                            <field name="codigo" readonly="1"/>
                            <field name="company_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        <group string="Annotation">
                            <group>
                                <field name="fecha" readonly="estado in ['closed']"/>
                                <label for="informado_por" string="Who"/>
                                <div class="o_row">
                                    <field name="informado_por" nolabel="1" options="{'no_create': True, 'no_open': True}"/>
                                    <span>(</span>
                                    <field name="rol_informa" nolabel="1" readonly="estado in ['pending', 'closed']"/>
                                    <span>)</span>
                                </div>
                            </group>
                            <group>
                                <field name="helicoptero_id" readonly="estado in ['pending', 'closed']" options="{'no_create': True, 'no_open': True}"/>
                                <field name="lugar" readonly="estado in ['pending', 'closed']"/>
                            </group>
                            <group colspan="2">
                                <field name="anotacion" readonly="estado in ['pending', 'closed']" colspan="2"/>
                            </group>
                        </group>
                        <group>
                            <group string="Close">
                                <field name="fecha_cierre" readonly="estado in ['edition','closed']"/>
                                <label for="cerrado_por" string="Who"/>
                                <div class="o_row">
                                    <field name="cerrado_por" nolabel="1"/>
                                    <span>(</span>
                                    <field name="rol_close" nolabel="1" readonly="((estado in ['edition', 'closed']))"/>
                                    <span>)</span>
                                </div>
                                <field name="accion_cierre" readonly="estado in ['edition','closed']"/>
                            </group>
                            <group string="CRS" invisible="rol_close != '2'">
                                <field name="fecha_crs" readonly="estado in ['edition','closed']"/>
                                <field name="crs_por"/>
                                <field name="lugar_crs" readonly="estado in ['edition','closed']"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>


        <record model="ir.actions.act_window" id="leulit_20260401_1013_action">
            <field name="name">Anotaciones Log Book</field>
            <field name="res_model">leulit.anotacion_technical_log</field>
            <field name="view_mode">tree,form</field>
        </record>


        <record id="leulit_anotacion_technical_log_mail_camo_estado" model="mail.template">
            <field name="name">Helipistas mail informa estado Anotación Log Book CAMO</field>
            <field name="model_id" ref="model_leulit_anotacion_technical_log" />
            <field name="email_from">erp@helipistas.com</field>
            <field name="email_to">albert@icarus-manteniment.com,otecnica@helipistas.com</field>
            <field name="subject">{{ ctx.get('subject') }}</field>
            <field name="auto_delete" eval="True" />
            <field name="body_html" type="html">
                <table border="0" cellpadding="0" cellspacing="0">
                    <tr>
                        <td>
                            Código:
                        </td>
                        <td>
                            <t t-out="object.codigo"/>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Estado:
                        </td>
                        <td>
                            <t t-out="object.estado"/>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Máquina:
                        </td>
                        <td>
                            <t t-out="object.helicoptero_id.name"/>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Anotación:
                        </td>
                        <td>
                            <t t-out="object.anotacion"/><br/>
                        </td>
                    </tr>
                    <t t-if="object.accion_cierre">
                        <tr>
                            <td>
                                Acción tomada:
                            </td>
                            <td>
                                <t t-out="object.accion_cierre"/>
                            </td>
                        </tr>
                    </t>
                </table>
            </field>
        </record>

    </data>
</odoo>