<odoo>

    <record id="leulit_wizard_cerrar_nc_form" model="ir.ui.view">
        <field name="name">leulit.wizard.cerrar.nc.form</field>
        <field name="model">leulit.wizard.cerrar.nc</field>
        <field name="arch" type="xml">
            <form string="Cerrar No Conformidad">
                <field name="nc_id" invisible="1" />
                <group>
                    <field name="immediate_action_id" />
                    <field name="motivo_cierre" />
                </group>
                <footer>
                    <button name="action_confirmar_cierre"
                            string="Cerrar NC"
                            type="object"
                            class="btn-primary" />
                    <button string="Cancelar" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

</odoo>
