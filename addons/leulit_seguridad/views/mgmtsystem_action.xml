        </record>
        <record id="leulit_20260427_1000_action_kanban_view" model="ir.actions.act_window.view">
            <field name="sequence" eval="10"/>
            <field name="view_mode">kanban</field>
            <field name="act_window_id" ref="leulit_20260427_1000_action"/>
            <field name="view_id" ref="project.project_kanban_view_group_stage"/>
        </record>
        <record id="leulit_20260427_1000_action_tree_view" model="ir.actions.act_window.view">
            <field name="sequence" eval="20"/>
            <field name="view_mode">tree</field>
            <field name="act_window_id" ref="leulit_20260427_1000_action"/>
            <field name="view_id" ref="project.project_list_view_group_stage"/>
        </record>

        <record id="leulit_20260112_0833_action" model="ir.actions.act_window">
            <field name="name">Mis Acciones</field>
            <field name="res_model">mgmtsystem.action</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">[("user_id", "=", uid)]</field>
            <field name="context">{'create': False, 'edit': False}</field>
        </record>

</odoo>