<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="leulit_wizard_nueva_anotacion_form" model="ir.ui.view">
            <field name="name">leulit_wizard_nueva_anotacion_form</field>
            <field name="model">leulit.wizard_nueva_anotacion</field>
            <field name="arch" type="xml">
                <form string="Nueva Anotación Log Book">
                    <group>
                        <field name="helicoptero_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="fecha"/>
                        <field name="hora_limite" placeholder="HH:MM"/>
                        <field name="vuelo_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="rol_informa"/>
                    </group>
                    <group>
                        <group string="Install">
                            <field name="instalar_dual_control"/>
                            <field name="instalar_cargo_hook_mirror"/>
                            <field name="instalar_floats"/>
                            <field name="instalar_life_raft"/>
                            <field name="instalar_life_vests_qty"/>
                            <field name="instalar_headsets_qty"/>
                            <field name="instalar_tyler"/>
                            <field name="instalar_gss"/>
                            <field name="instalar_cineflex"/>
                            <field name="instalar_lidar_system"/>
                            <field name="instalar_af120"/>
                        </group>
                        <group string="Remove">
                            <field name="remover_dual_control"/>
                            <field name="remover_cargo_hook_mirror"/>
                            <field name="remover_floats"/>
                            <field name="remover_life_raft"/>
                            <field name="remover_life_vests_qty"/>
                            <field name="remover_headsets_qty"/>
                            <field name="remover_tyler"/>
                            <field name="remover_gss"/>
                            <field name="remover_cineflex"/>
                            <field name="remover_lidar_system"/>
                            <field name="remover_af120"/>
                        </group>
                    </group>
                    <group string="Annotation">
                        <field name="anotacion" nolabel="1" colspan="2" readonly="1" force_save="1"/>
                    </group>
                    <footer>
                        <button name="action_crear_anotacion" type="object" string="Crear Anotación" class="oe_highlight"/>
                        <button special="cancel" string="Cancelar"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
