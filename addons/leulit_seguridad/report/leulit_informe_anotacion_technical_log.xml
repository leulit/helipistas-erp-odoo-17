<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <template id="anotacion_technical_log_report_css">
            <meta charset="utf-8"/>
            <style>
                .footer {
                    position:absolute;
                    bottom:-350px
                }
                .noborde {
                    border:0 solid #ffffff;
                    border-collapse: collapse;
                    border-spacing: 0;
                }
                table.estructura {
                    width:100%
                }
                table.anomalia {
                    border:thin solid #E3E4EA;
                    text-align:center;
                    border-collapse: collapse;
                    border-spacing: 0;
                }
                table.anomalia th, table.anomalia tbody td, table.anomalia tfoot td {
                    border: 1px solid #E3E4EA;
                    padding-right:3px;
                    padding-left:3px;
                    text-align:center;
                    font-size:10px;
                }
                .campo1{
                    font-weight: bold;
                    font-size: 13px;º
                }
                .campo2{
                    font-weight: bold;
                    font-size: 10px;
                }
                .anomalia_tabla{
                    margin-top: 5px;
                }
                #textos td{
                    width: 50%;
                    padding: 10px;
                    padding-bottom: 0px;
                    vertical-align:top;
                    text-align: left;
                    border: 1px solid white;
                }
                #textos td p{
                    font-size: 10px;
                }
                #codigo {
                    height: 25px;
                }
                #codigo td{
                    padding: 10px;
                    vertical-align:middle;
                    text-align: left;
                    border-top: 1px solid white;
                    border-left: 1px solid white;
                    border-right: 1px solid white;
                    border-bottom: 1px solid #E3E4EA;
                }
                #codigo td p{
                    font-size: 13px;
                }
                #datos_fila_1{
                    height: 45px;
                }
                #datos_fila_1 td{
                    padding: 10px;
                    vertical-align:middle;
                    text-align: left;
                    border: 1px solid #E3E4EA;
                    width: 25%;
                }
                #datos_fila_1 td p{
                    font-size: 10px;
                }
                #datos_fila_2{
                    height: 200px;
                }
                #datos_fila_2 td{
                    padding: 10px;
                    vertical-align:top;
                    text-align: left;
                    border: 1px solid #E3E4EA;
                }
                #datos_fila_2 td h3{
                    font-size: 13px;
                    margin-bottom:2px;
                    padding-bottom:10px;
                }
                #datos_fila_2 td p{
                    font-size: 10px;
                }
                #datos_fila_3{
                    height: 15px;
                }
                #datos_fila_3 td{
                    padding: 10px;
                    vertical-align:top;
                    text-align: left;
                    border: 1px solid #E3E4EA;
                    border-bottom: 1px solid white;
                }
                #datos_fila_3 td h3{
                    font-size: 13px;
                }
                #datos_fila_4{
                    height: 40px;
                    border-bottom: 1px solid #E3E4EA;

                }
                #datos_fila_4 td{
                    padding: 10px;
                    padding-top: 0px;
                    vertical-align:top;
                    text-align: left;
                    border: 1px solid #E3E4EA;

                }
                #datos_fila_4 td h3{
                    font-size: 13px;
                    margin-bottom:2px;
                }
                #datos_fila_4 td p{
                    font-size: 10px;
                }
                #datos_fila_5{
                    height: 200px;
                }
                #datos_fila_5 td{
                    padding: 10px;
                    vertical-align:top;
                    text-align: left;
                    border: 1px solid #E3E4EA;
                }
                #datos_fila_5 td h3{
                    padding-bottom:10px;
                    font-size: 13px;
                    margin-bottom:2px;
                }
                #datos_fila_5 td p{
                    font-size: 10px;
                }
                .version_doc td{
                    font-size: 12px;
                    padding:5px;
                }
                #footer_text{
                    width:80%;
                    text-align:left;
                    vertical-align:middle;
                }
                #footer_text p{
                    margin-top:2px;
                    font-size:10px;
                    padding-left: 10px;
                }
                #footer_qr{
                    vertical-align:middle;
                }
                .firma{
                    text-align: right;
                    padding-top:5px;
                    padding-right: 20px;
                }
                .fullwidth {
                    width: 100%;
                }
            </style>
        </template>

        <template id="leulit_20260414_1111_informe">
            <t t-call="web.html_container">     
                <div class="page">
                    <t t-call="leulit_seguridad.anotacion_technical_log_report_css"/>
                    <div class="row">
                        <table class="fullwidth">
                            <tr>
                                <th>
                                    <table>
                                        <tr>
                                            <td class="noborde" style="font-size:8px; white-space: nowrap; text-align:center">(c) Helipistas</td>
                                            <td class="noborde" style="font-size:8px; white-space: nowrap; text-align:center">
                                                <i>Fecha creación documento</i><br/>
                                                <i><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d-%m-%Y')"/></i>
                                            </td>
                                            <td class="noborde" style="font-size:8px; white-space: nowrap; text-align:center">
                                                <t t-if="hashcode">
                                                    <i>Firmado por:</i><br/>
                                                    <i><span t-esc="firmado_por"/></i>
                                                </t>
                                            </td>
                                            <td class="noborde" style="font-size:8px; white-space: nowrap; text-align:center">
                                                <t t-if="hashcode">
                                                    <i>CSV/CID</i><br/>
                                                    <span t-esc="hashcode"/>
                                                </t>
                                                <t t-if="not hashcode">
                                                    <i>Referencia</i><br/>
                                                    <span t-esc="hashcode_interno"/>
                                                </t>
                                            </td>
                                        </tr>
                                    </table>
                                </th>
                                <th>
                                    <table align="right">
                                        <tr>
                                            <td style="font-size:8px; white-space: nowrap; text-align:center" class="noborde"><b>Código:</b></td>
                                            <td style="font-size:8px; white-space: nowrap; text-align:center" class="noborde">HLP-DOC-0013</td>
                                            <td style="font-size:8px; white-space: nowrap; text-align:center" class="noborde"><b>Versión:</b></td>
                                            <td style="font-size:8px; white-space: nowrap; text-align:center" class="noborde">1.0.0</td>
                                        </tr>
                                    </table>
                                </th>
                            </tr>
                            <tr>
                                <th colspan="2" style="border-top: 1px solid #575757;">
                                    <table class="fullwidth">
                                        <tbody>
                                            <tr>
                                                <td colspan="2" class="noborde" style="font-size:8px;width:100%; text-align:center">
                                                    Cualquier copia total o parcial de este documento se considera copia no controlada y siempre deberá ser contrastada con la información vigente en la intranet. (https://erp.helipistas.com/verifycsv)
                                                </td>
                                            </tr>
                                            <tr class="noborde">
                                                <td class="noborde">
                                                    <table class="anomalia_tabla anomalia fullwidth">
                                                        <tr>
                                                            <th style="text-align:center;vertical-align: middle" class="noborder" colspan="2">
                                                                <img t-att-src="'data:image/png;base64,%s' % logo" style="width:auto;height:50px;"/>
                                                            </th>
                                                            <th class="literal theadtitle centertext" style="width:100%; font-size:17px" colspan="8">
                                                                ANOTATION TECHNICAL LOG
                                                            </th>
                                                            <th class="literal centertext"><div style="text-transform: uppercase; font-size:17px;"><span t-esc="estado"/></div></th>
                                                        </tr>
                                                    </table>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </th>
                            </tr>
                        </table>
                        <table  class="estructura fullwidth noborde">
                            <tr class="noborde">
                                <td class="noborde">
                                    <table class="anomalia_tabla anomalia fullwidth">
                                        <tr id="codigo">
                                            <td colspan="12" style="font-size:18px">
                                                <b>CODE:</b>
                                                <t t-if="codigo">
                                                    <span t-esc="codigo"/>
                                                </t>
                                                <t t-if="not codigo">
                                                    <span t-esc="id"/> - (ID)
                                                </t>
                                            </td>
                                        </tr>
                                        <tr id="datos_fila_2">
                                            <td colspan="12">
                                                <h3>REPORT</h3>
                                                <p><span class="campo2">Date:</span> <span t-esc="fecha"/></p>
                                                <p><span class="campo2">Who:</span> <span t-esc="informado_por"/>  (<span t-esc="rol_informa"/>)</p>
                                                <p><span class="campo2">Place:</span> <span t-esc="lugar"/></p>
                                                <p><span class="campo2">Comment:</span> <span t-esc="anotacion"/></p>
                                            </td>
                                        </tr>
                                        <tr id="datos_fila_5">
                                            <td colspan="6">
                                                <h3>ACTION TAKEN / CLOSE</h3>
                                                <p><span class="campo2">Date:</span> 
                                                    <span t-esc="fecha_cierre"/>
                                                </p>
                                                <p><span class="campo2">Who:</span> 
                                                    <span t-esc="cerrado_por"/> (<span t-esc="rol_close"/>)<br/><span t-esc="cerrado_por_company"/>
                                                </p>
                                                <p><span class="campo2">Reason:</span> 
                                                    <span t-esc="accion_cierre"/>
                                                </p>
                                            </td>
                                            <td colspan="6">
                                                <h3>CRS</h3>
                                                <p><span class="campo2">Date:</span>
                                                    <t t-if="fecha_crs">
                                                        <span t-esc="fecha_crs"/>
                                                    </t>
                                                    <t t-if="not fecha_crs">
                                                        <span>N/A</span>
                                                    </t>
                                                </p>
                                                <p><span class="campo2">Who:</span>
                                                    <t t-if="crs_por">
                                                        <span t-esc="crs_por"/>
                                                    </t>
                                                    <t t-if="not crs_por">
                                                        <span>N/A</span>
                                                    </t>
                                                </p>
                                                <p><span class="campo2">Place:</span>
                                                    <t t-if="lugar_crs">
                                                        <span t-esc="lugar_crs"/>
                                                    </t>
                                                    <t t-if="not lugar_crs">
                                                        <span>N/A</span>
                                                    </t>
                                                </p>
                                                <p><span class="campo2">CAS:</span> 
                                                    <t t-if="hashcode">
                                                        <span t-esc="hashcode"/>
                                                    </t>
                                                    <t t-if="not hashcode">
                                                        <span>N/A</span>
                                                    </t>
                                                </p>
                                                <p>
                                                    Certifies that the work specified except as otherwise specified was carried out in
                                                    accordance with Part 145 and in respect to that work the aircraft is considered ready
                                                    for Release to Service.
                                                </p>
                                            </td>
                                        </tr>
                                        <tr id="textos">
                                            <td colspan="12">
                                                
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </t>
        </template>


    </data>
</odoo>