<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_leulit_ia" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.leulit.ia</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-key="leulit_ia"
                     string="Leulit IA" groups="base.group_system">

                    <h2>Asistente IA</h2>

                    <!-- Proveedor -->
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="ia_provider" string="Proveedor IA"/>
                                <div class="text-muted">
                                    Selecciona el motor de lenguaje a utilizar.
                                </div>
                                <div class="content-group mt8">
                                    <field name="ia_provider" widget="radio"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Claude API Key -->
                    <div class="row mt16 o_settings_container"
                         attrs="{'invisible': [('ia_provider', '!=', 'claude')]}">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="ia_claude_api_key"/>
                                <div class="text-muted">
                                    API Key de Anthropic Claude.
                                    Obtén una en
                                    <a href="https://console.anthropic.com/" target="_blank">
                                        console.anthropic.com
                                    </a>.
                                </div>
                                <div class="content-group mt8">
                                    <field name="ia_claude_api_key"
                                           password="True"
                                           placeholder="sk-ant-..."/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Ollama URL + modelo -->
                    <div class="row mt16 o_settings_container"
                         attrs="{'invisible': [('ia_provider', '!=', 'ollama')]}">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="ia_ollama_url"/>
                                <div class="text-muted">
                                    URL base del servidor Ollama (ej: http://localhost:11434).
                                </div>
                                <div class="content-group mt8">
                                    <field name="ia_ollama_url"
                                           placeholder="http://localhost:11434"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="ia_ollama_model"/>
                                <div class="text-muted">
                                    Nombre del modelo Ollama (ej: llama3, mistral).
                                </div>
                                <div class="content-group mt8">
                                    <field name="ia_ollama_model" placeholder="llama3"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Parámetros avanzados -->
                    <h3 class="mt16">Parámetros avanzados</h3>
                    <div class="row mt8 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="ia_temperature"/>
                                <div class="text-muted">
                                    Aleatoriedad de las respuestas (0.0–1.0). Recomendado: 0.3.
                                </div>
                                <div class="content-group mt8">
                                    <field name="ia_temperature"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="ia_max_tokens"/>
                                <div class="text-muted">
                                    Límite de tokens en la respuesta del modelo.
                                </div>
                                <div class="content-group mt8">
                                    <field name="ia_max_tokens"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Botón de prueba -->
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <button string="Probar conexión"
                                        name="action_test_ia_connection"
                                        type="object"
                                        class="btn btn-secondary mt8"/>
                            </div>
                        </div>
                    </div>

                </div>
            </xpath>
        </field>
    </record>
</odoo>
