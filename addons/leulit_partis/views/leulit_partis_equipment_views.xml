<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_leulit_partis_equipment_tree" model="ir.ui.view">
        <field name="name">leulit.partis.equipment.tree</field>
        <field name="model">leulit.partis.equipment</field>
        <field name="arch" type="xml">
            <tree string="Equipos IT">
                <field name="inventory_code"/>
                <field name="name"/>
                <field name="device_type"/>
                <field name="manufacturer"/>
                <field name="serial_number"/>
                <field name="assigned_user_id"/>
                <field name="location"/>
                <field name="encryption_enabled"/>
                <field name="antivirus_enabled"/>
                <field name="state" decoration-success="state == 'in_service'" decoration-warning="state == 'repair'" decoration-muted="state == 'retired'"/>
            </tree>
        </field>
    </record>

    <record id="view_leulit_partis_equipment_form" model="ir.ui.view">
        <field name="name">leulit.partis.equipment.form</field>
        <field name="model">leulit.partis.equipment</field>
        <field name="arch" type="xml">
            <form string="Equipo IT">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Ej: Portátil Dirección"/></h1>
                    </div>
                    <group>
                        <group string="Identificación">
                            <field name="inventory_code"/>
                            <field name="device_type"/>
                            <field name="manufacturer"/>
                            <field name="model_name"/>
                            <field name="serial_number"/>
                        </group>
                        <group string="Asignación">
                            <field name="assigned_user_id"/>
                            <field name="department_id"/>
                            <field name="location"/>
                            <field name="state"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <group string="Ciclo de vida">
                            <field name="purchase_date"/>
                            <field name="warranty_end_date"/>
                            <field name="warranty_active" readonly="1"/>
                        </group>
                        <group string="Seguridad SGSI PART-IS">
                            <field name="encryption_enabled"/>
                            <field name="antivirus_enabled"/>
                            <field name="patch_status"/>
                            <field name="asset_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_leulit_partis_equipment_search" model="ir.ui.view">
        <field name="name">leulit.partis.equipment.search</field>
        <field name="model">leulit.partis.equipment</field>
        <field name="arch" type="xml">
            <search string="Buscar Equipos IT">
                <field name="name"/>
                <field name="inventory_code"/>
                <field name="serial_number"/>
                <field name="assigned_user_id"/>
                <filter name="in_service" string="En servicio" domain="[('state','=','in_service')]"/>
                <filter name="retired" string="Retirados" domain="[('state','=','retired')]"/>
                <separator/>
                <filter name="no_encryption" string="Sin cifrado" domain="[('encryption_enabled','=',False)]"/>
                <filter name="no_antivirus" string="Sin antivirus" domain="[('antivirus_enabled','=',False)]"/>
                <filter name="warranty_expired" string="Garantía caducada" domain="[('warranty_active','=',False)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_device_type" string="Tipo de equipo" context="{'group_by':'device_type'}"/>
                    <filter name="group_state" string="Estado" context="{'group_by':'state'}"/>
                    <filter name="group_department" string="Departamento" context="{'group_by':'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_leulit_partis_equipment" model="ir.actions.act_window">
        <field name="name">Inventario de Equipos IT</field>
        <field name="res_model">leulit.partis.equipment</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_leulit_partis_equipment_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Registrar un nuevo equipo IT</p>
            <p>Inventario de equipos informáticos (ordenadores, portátiles, tablets, móviles, servidores)
               para el cumplimiento del SGSI PART-IS / AESA.</p>
        </field>
    </record>

    <menuitem id="menu_leulit_partis_equipment"
        name="Inventario de Equipos IT"
        parent="menu_leulit_riesgo_root"
        action="action_leulit_partis_equipment"
        sequence="25"/>
</odoo>
