<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form del wizard buscador -->
    <record id="view_leulit_meteo_aemet_station_finder_form"
            model="ir.ui.view">
        <field name="name">leulit.meteo.aemet.station.finder.form</field>
        <field name="model">leulit.meteo.aemet.station.finder</field>
        <field name="arch" type="xml">
            <form string="Buscar estación AEMET">
                <sheet>
                    <div class="oe_title">
                        <h2>Buscar estación AEMET</h2>
                        <p>
                            Busque por nombre, provincia o indicativo. El
                            inventario incluye más de 700 estaciones, no
                            todas en aeródromos.
                        </p>
                    </div>
                    <group>
                        <field name="metar_id" invisible="1"/>
                        <field name="search_term"
                               placeholder="ej: SABADELL, BARCELONA, 0149X..."/>
                    </group>
                    <div>
                        <button name="action_buscar"
                                type="object"
                                string="Buscar"
                                class="btn-primary"
                                icon="fa-search"/>
                    </div>
                    <field name="result_ids" nolabel="1">
                        <tree string="Resultados" create="false" delete="false"
                              edit="false">
                            <field name="indicativo"/>
                            <field name="nombre"/>
                            <field name="provincia"/>
                            <field name="latitud" optional="show"/>
                            <field name="longitud" optional="show"/>
                            <field name="altitud" optional="hide"/>
                            <button name="action_aplicar"
                                    type="object"
                                    string="Aplicar"
                                    class="btn-primary"
                                    icon="fa-check"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button string="Cerrar" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción independiente (para abrir desde menú o pruebas) -->
    <record id="action_leulit_meteo_aemet_station_finder"
            model="ir.actions.act_window">
        <field name="name">Buscar estación AEMET</field>
        <field name="res_model">leulit.meteo.aemet.station.finder</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
