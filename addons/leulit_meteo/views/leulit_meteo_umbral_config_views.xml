<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_leulit_meteo_umbral_config_form" model="ir.ui.view">
        <field name="name">leulit.meteo.umbral.config.form</field>
        <field name="model">leulit.meteo.umbral.config</field>
        <field name="arch" type="xml">
            <form string="Umbrales Operacionales">
                <sheet>
                    <style>
                        .u-title {
                            font-size: 13pt;
                            font-weight: 700;
                            color: #1a3a5c;
                            margin: 0 0 20px 0;
                        }
                        .u-section {
                            border-left: 3px solid #1a3a5c;
                            padding: 10px 16px;
                            margin-bottom: 20px;
                        }
                        .u-section-name {
                            font-size: 9pt;
                            font-weight: 700;
                            text-transform: uppercase;
                            letter-spacing: 0.06em;
                            color: #1a3a5c;
                            margin-bottom: 10px;
                        }
                        .u-fields {
                            display: flex;
                            gap: 40px;
                            align-items: flex-end;
                        }
                        .u-field label.o_form_label {
                            display: block;
                            font-size: 8.5pt;
                            font-weight: 700;
                            text-transform: uppercase;
                            letter-spacing: 0.04em;
                            margin-bottom: 3px;
                        }
                        .u-field.marginal label.o_form_label { color: #fd7e14; }
                        .u-field.nogo     label.o_form_label { color: #dc3545; }
                        .u-note {
                            font-size: 8.5pt;
                            color: #6c757d;
                            margin-top: 6px;
                            font-style: italic;
                        }
                    </style>

                    <div class="u-title">Umbrales Operacionales</div>

                    <!-- VIENTO SOSTENIDO -->
                    <div class="u-section">
                        <div class="u-section-name">Viento sostenido</div>
                        <div class="u-fields">
                            <div class="u-field marginal">
                                <label for="viento_marginal_kt" string="Marginal (kt)" class="o_form_label"/>
                                <field name="viento_marginal_kt" nolabel="1"/>
                            </div>
                            <div class="u-field nogo">
                                <label for="viento_nogo_kt" string="No Go (kt)" class="o_form_label"/>
                                <field name="viento_nogo_kt" nolabel="1"/>
                            </div>
                        </div>
                    </div>

                    <!-- RACHAS -->
                    <div class="u-section">
                        <div class="u-section-name">Rachas</div>
                        <div class="u-fields">
                            <div class="u-field marginal">
                                <label for="rachas_marginal_kt" string="Marginal (kt)" class="o_form_label"/>
                                <field name="rachas_marginal_kt" nolabel="1"/>
                            </div>
                            <div class="u-field nogo">
                                <label for="rachas_nogo_kt" string="No Go (kt)" class="o_form_label"/>
                                <field name="rachas_nogo_kt" nolabel="1"/>
                            </div>
                        </div>
                    </div>

                    <!-- VISIBILIDAD -->
                    <div class="u-section">
                        <div class="u-section-name">Visibilidad</div>
                        <div class="u-fields">
                            <div class="u-field marginal">
                                <label for="vis_marginal_m" string="Marginal (m)" class="o_form_label"/>
                                <field name="vis_marginal_m" nolabel="1"/>
                            </div>
                            <div class="u-field nogo">
                                <label for="vis_nogo_m" string="No Go (m)" class="o_form_label"/>
                                <field name="vis_nogo_m" nolabel="1"/>
                            </div>
                        </div>
                        <div class="u-note">A menor visibilidad, mayor restricción.</div>
                    </div>

                </sheet>
                <footer>
                    <button name="action_save"
                            string="Guardar umbrales"
                            type="object"
                            class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_leulit_meteo_umbral_config" model="ir.actions.act_window">
        <field name="name">Umbrales Operacionales</field>
        <field name="res_model">leulit.meteo.umbral.config</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_leulit_meteo_umbral_config_form"/>
    </record>

</odoo>
