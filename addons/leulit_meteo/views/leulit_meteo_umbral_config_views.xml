<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_leulit_meteo_umbral_config_form" model="ir.ui.view">
        <field name="name">leulit.meteo.umbral.config.form</field>
        <field name="model">leulit.meteo.umbral.config</field>
        <field name="arch" type="xml">
            <form string="Umbrales Operacionales">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Estos valores determinan el estado meteorológico calculado en los
                        partes de vuelo. Ajústalos a los mínimos de tu Manual de Operaciones
                        u OpsSpec. Los cambios se aplican a todas las consultas nuevas.
                    </div>

                    <group string="Viento sostenido">
                        <group>
                            <field name="viento_marginal_kt"
                                   decoration-warning="True"/>
                            <field name="viento_nogo_kt"
                                   decoration-danger="True"/>
                        </group>
                        <group>
                            <div class="text-muted o_field_widget" colspan="2">
                                <ul class="mb-0">
                                    <li>Por debajo de <strong><field name="viento_marginal_kt" readonly="1" nolabel="1"/> kt</strong>: estado <span class="badge bg-success">OK</span></li>
                                    <li>Entre <strong><field name="viento_marginal_kt" readonly="1" nolabel="1"/> y <field name="viento_nogo_kt" readonly="1" nolabel="1"/> kt</strong>: estado <span class="badge bg-warning">MARGINAL</span></li>
                                    <li>Por encima de <strong><field name="viento_nogo_kt" readonly="1" nolabel="1"/> kt</strong>: estado <span class="badge bg-danger">NO GO</span></li>
                                </ul>
                            </div>
                        </group>
                    </group>

                    <group string="Rachas">
                        <group>
                            <field name="rachas_marginal_kt"/>
                            <field name="rachas_nogo_kt"/>
                        </group>
                    </group>

                    <group string="Visibilidad">
                        <group>
                            <field name="vis_marginal_m"/>
                            <field name="vis_nogo_m"/>
                        </group>
                        <group>
                            <div class="text-muted" colspan="2">
                                Por encima de <strong><field name="vis_marginal_m" readonly="1" nolabel="1"/> m</strong>: OK —
                                entre <strong><field name="vis_nogo_m" readonly="1" nolabel="1"/> y <field name="vis_marginal_m" readonly="1" nolabel="1"/> m</strong>: MARGINAL —
                                por debajo de <strong><field name="vis_nogo_m" readonly="1" nolabel="1"/> m</strong>: NO GO
                            </div>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_save"
                            string="Guardar"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_leulit_meteo_umbral_config" model="ir.actions.act_window">
        <field name="name">Umbrales Operacionales</field>
        <field name="res_model">leulit.meteo.umbral.config</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_leulit_meteo_umbral_config_form"/>
        <field name="target">new</field>
    </record>

</odoo>
