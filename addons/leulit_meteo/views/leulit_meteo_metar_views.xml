<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree -->
    <record id="view_leulit_meteo_metar_tree" model="ir.ui.view">
        <field name="name">leulit.meteo.metar.tree</field>
        <field name="model">leulit.meteo.metar</field>
        <field name="arch" type="xml">
            <tree string="Reportes METAR/TAF/SIGMET"
                  decoration-success="estado_datos == 'actual'"
                  decoration-warning="estado_datos == 'reciente'"
                  decoration-danger="estado_datos == 'antiguo'"
                  decoration-muted="not observation_time"
                  decoration-info="usa_referencia">
                <field name="codigo"/>
                <field name="provider" widget="badge"/>
                <field name="icao_code"/>
                <field name="ref_icao" optional="show"/>
                <field name="usa_referencia" optional="hide"/>
                <field name="fir_code" optional="show"/>
                <field name="station_name"/>
                <field name="observation_time"/>
                <field name="edad_datos" optional="show"/>
                <field name="estado_datos" widget="badge"
                       decoration-success="estado_datos == 'actual'"
                       decoration-warning="estado_datos == 'reciente'"
                       decoration-danger="estado_datos == 'antiguo'"/>
                <field name="temperatura"/>
                <field name="wind_speed_kt"/>
                <field name="wind_direction"/>
                <field name="visibility_m"/>
                <field name="qnh"/>
                <field name="user_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Form -->
    <record id="view_leulit_meteo_metar_form" model="ir.ui.view">
        <field name="name">leulit.meteo.metar.form</field>
        <field name="model">leulit.meteo.metar</field>
        <field name="arch" type="xml">
            <form string="Reporte METAR/TAF/SIGMET">
                <header>
                    <button name="action_obtener_briefing"
                            string="Obtener briefing"
                            type="object"
                            class="btn-primary"
                            icon="fa-cloud-download"/>
                    <field name="estado_datos" widget="statusbar"
                           statusbar_visible="actual,reciente,antiguo"/>
                </header>

                <div class="alert alert-info" role="alert"
                     invisible="not usa_referencia">
                    <i class="fa fa-info-circle"/>
                    <field name="aviso_referencia" readonly="1" nolabel="1"/>
                </div>

                <div class="alert alert-warning" role="alert"
                     invisible="not raw_metar and not raw_taf and not raw_sigmet">
                    <i class="fa fa-exclamation-triangle"/>
                    Información orientativa. Verifique siempre NOTAM y el
                    autoservicio briefing oficial. Fuente: AEMET OpenData.
                </div>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="icao_code"
                                   placeholder="ej: LEMD"
                                   style="text-transform:uppercase"/>
                        </h1>
                        <h3>
                            <field name="codigo" readonly="1"/>
                            -
                            <field name="station_name" readonly="1"
                                   placeholder="Aeródromo..."/>
                        </h3>
                    </div>

                    <group>
                        <group string="Proveedor / Aeródromo">
                            <field name="provider"/>
                            <field name="fir_code" readonly="1"/>
                            <field name="usa_referencia" readonly="1"/>
                            <field name="ref_icao" readonly="1"
                                   invisible="not usa_referencia"/>
                            <field name="ref_nombre" readonly="1"
                                   invisible="not usa_referencia"/>
                            <field name="ref_distancia_km" readonly="1"
                                   invisible="not usa_referencia"/>
                        </group>
                        <group string="Tiempos">
                            <field name="observation_time" string="Observación (UTC)"/>
                            <field name="observation_time_local" string="Observación (Madrid)" readonly="1"/>
                            <field name="edad_datos" readonly="1"/>
                            <field name="fecha_consulta" string="Consulta (UTC)"/>
                            <field name="fecha_consulta_local" string="Consulta (Madrid)" readonly="1"/>
                            <field name="user_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="METAR" name="metar">
                            <group>
                                <field name="provider" readonly="1"
                                       widget="badge" string="Fuente"/>
                                <field name="ref_icao" readonly="1"
                                       string="OACI consultado"
                                       invisible="not usa_referencia"/>
                                <field name="icao_code" readonly="1"
                                       string="OACI consultado"
                                       invisible="usa_referencia"/>
                            </group>
                            <field name="raw_metar" nolabel="1"
                                   widget="text"
                                   placeholder="Pulse 'Obtener briefing' para traer el METAR oficial..."/>
                        </page>

                        <page string="TAF" name="taf">
                            <group>
                                <field name="provider" readonly="1"
                                       widget="badge" string="Fuente"/>
                                <field name="ref_icao" readonly="1"
                                       string="OACI consultado"
                                       invisible="not usa_referencia"/>
                                <field name="icao_code" readonly="1"
                                       string="OACI consultado"
                                       invisible="usa_referencia"/>
                            </group>
                            <field name="raw_taf" nolabel="1"
                                   widget="text"
                                   placeholder="Pulse 'Obtener briefing' para traer el TAF oficial..."/>
                        </page>

                        <page string="SIGMET" name="sigmet">
                            <group>
                                <field name="fir_code" readonly="1"
                                       string="FIR consultada"/>
                            </group>
                            <field name="raw_sigmet" nolabel="1"
                                   widget="text"
                                   placeholder="SIGMET vigentes para la FIR (puede no haber ninguno)..."/>
                        </page>

                        <page string="Datos decodificados" name="decoded">
                            <p class="text-muted">
                                Campos extraídos del METAR de forma
                                automática (best-effort). El RAW de
                                arriba prevalece ante cualquier duda.
                            </p>
                            <group>
                                <group string="Temperatura">
                                    <field name="temperatura"/>
                                    <field name="dewpoint"/>
                                </group>
                                <group string="Presión">
                                    <field name="qnh"/>
                                </group>
                            </group>
                            <group>
                                <group string="Viento">
                                    <field name="wind_direction"/>
                                    <field name="wind_speed_kt"/>
                                    <field name="wind_gust_kt"/>
                                </group>
                                <group string="Visibilidad">
                                    <field name="visibility_m"/>
                                </group>
                            </group>
                        </page>

                        <page string="Información técnica" name="tecnica">
                            <group>
                                <group string="Resolución">
                                    <field name="fir_code" readonly="1"/>
                                    <field name="ref_icao" readonly="1"/>
                                    <field name="ref_nombre" readonly="1"/>
                                    <field name="usa_referencia" readonly="1"/>
                                </group>
                                <group string="Estación (proveedor)"
                                       invisible="provider == 'aemet'">
                                    <field name="station_code" readonly="1"/>
                                </group>
                            </group>
                            <group>
                                <group string="Coordenadas / elevación">
                                    <field name="latitud" readonly="1"/>
                                    <field name="longitud" readonly="1"/>
                                    <field name="elevation" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Notas" name="notas">
                            <field name="notas"
                                   placeholder="Notas adicionales..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search -->
    <record id="view_leulit_meteo_metar_search" model="ir.ui.view">
        <field name="name">leulit.meteo.metar.search</field>
        <field name="model">leulit.meteo.metar</field>
        <field name="arch" type="xml">
            <search string="Buscar METAR">
                <field name="codigo"/>
                <field name="icao_code"/>
                <field name="ref_icao"/>
                <field name="fir_code"/>
                <field name="station_name"/>
                <field name="provider"/>
                <field name="observation_time"/>

                <filter string="Datos actuales" name="filter_actual"
                        domain="[('estado_datos','=','actual')]"/>
                <filter string="Datos recientes" name="filter_reciente"
                        domain="[('estado_datos','=','reciente')]"/>
                <filter string="Datos antiguos" name="filter_antiguo"
                        domain="[('estado_datos','=','antiguo')]"/>
                <separator/>
                <filter string="Usa referencia" name="filter_usa_ref"
                        domain="[('usa_referencia','=',True)]"/>
                <separator/>
                <filter string="Mis consultas" name="filter_mis"
                        domain="[('user_id','=',uid)]"/>

                <group expand="0" string="Agrupar por">
                    <filter string="Proveedor" name="group_provider"
                            context="{'group_by': 'provider'}"/>
                    <filter string="OACI" name="group_icao"
                            context="{'group_by': 'icao_code'}"/>
                    <filter string="FIR" name="group_fir"
                            context="{'group_by': 'fir_code'}"/>
                    <filter string="Usuario" name="group_user"
                            context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_leulit_meteo_metar" model="ir.actions.act_window">
        <field name="name">Reportes METAR</field>
        <field name="res_model">leulit.meteo.metar</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id"
               ref="view_leulit_meteo_metar_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo briefing METAR/TAF/SIGMET
            </p>
            <p>
                Introduzca el código OACI del aeródromo y pulse
                <b>Obtener briefing</b> para traer METAR + TAF + SIGMET
                oficiales de AEMET. Si el OACI no emite METAR propio se
                usará el aeródromo de referencia configurado.
            </p>
        </field>
    </record>

</odoo>
