<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_leulit_meteo_icao_reference_tree" model="ir.ui.view">
        <field name="name">leulit.meteo.icao.reference.tree</field>
        <field name="model">leulit.meteo.icao.reference</field>
        <field name="arch" type="xml">
            <tree string="Aeródromos de Referencia">
                <field name="icao"/>
                <field name="nombre"/>
                <field name="fir"/>
                <field name="proveedor_oficial" widget="badge"/>
                <field name="proxima_actualizacion_local"/>
                <field name="ultima_ejecucion_cron_local" optional="show" string="Últ. ejecución cron"/>
                <field name="elevacion_ft"/>
            </tree>
        </field>
    </record>

    <record id="view_leulit_meteo_icao_reference_form" model="ir.ui.view">
        <field name="name">leulit.meteo.icao.reference.form</field>
        <field name="model">leulit.meteo.icao.reference</field>
        <field name="arch" type="xml">
            <form string="Aeródromo de Referencia">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_historico"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-history">
                            <field name="historico_count" widget="statinfo"
                                   string="Histórico"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="icao"
                                   placeholder="OACI 4 letras"
                                   style="text-transform:uppercase"/>
                        </h1>
                        <h3><field name="nombre" placeholder="Nombre del punto"/></h3>
                    </div>
                    <group>
                        <group string="Identificación">
                            <field name="fir"/>
                            <field name="proveedor_oficial" readonly="1"/>
                        </group>
                        <group string="Coordenadas">
                            <field name="latitud" readonly="1"/>
                            <field name="longitud" readonly="1"/>
                            <field name="elevacion_ft"/>
                        </group>
                        <group string="Estado cron">
                            <field name="ultima_ejecucion_cron_local" readonly="1"/>
                            <field name="proxima_actualizacion_local" readonly="1"/>
                            <field name="proxima_actualizacion_utc" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="METAR / TAF" name="metar_taf">
                            <field name="historico_ids" nolabel="1" readonly="1">
                                <tree limit="5" create="0" delete="0" editable="0"
                                      decoration-muted="not raw_metar">
                                    <field name="observation_time_local" string="Observación (Madrid)"/>
                                    <field name="observation_time_utc" string="Obs. (UTC)" optional="show"/>
                                    <field name="edad_datos" string="Actualización"/>
                                    <field name="raw_metar" string="METAR"/>
                                    <field name="raw_taf" string="TAF" optional="show"/>
                                    <field name="fuente_metar" string="Fuente" optional="show"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notas" name="notas">
                            <field name="notas" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_leulit_meteo_icao_reference_search" model="ir.ui.view">
        <field name="name">leulit.meteo.icao.reference.search</field>
        <field name="model">leulit.meteo.icao.reference</field>
        <field name="arch" type="xml">
            <search string="Buscar aeródromo">
                <field name="icao"/>
                <field name="nombre"/>
                <field name="fir"/>
                <separator/>
                <filter string="FIR Madrid (LECM)" name="filter_lecm"
                        domain="[('fir','=','LECM')]"/>
                <filter string="FIR Barcelona (LECB)" name="filter_lecb"
                        domain="[('fir','=','LECB')]"/>
                <filter string="FIR Canarias (GCCC)" name="filter_gccc"
                        domain="[('fir','=','GCCC')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="FIR" name="group_fir"
                            context="{'group_by': 'fir'}"/>
                    <filter string="Proveedor" name="group_proveedor"
                            context="{'group_by': 'proveedor_oficial'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_leulit_meteo_icao_reference"
            model="ir.actions.act_window">
        <field name="name">Aeródromos de Referencia</field>
        <field name="res_model">leulit.meteo.icao.reference</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id"
               ref="view_leulit_meteo_icao_reference_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Añade un aeródromo de referencia
            </p>
            <p>
                Esta tabla contiene los aeródromos con METAR/TAF oficiales.
                Se consulta cada vez que se pide un briefing METAR/TAF/SIGMET.
                Para un OACI desconocido, el sistema busca automáticamente
                el aeródromo de referencia más próximo.
            </p>
        </field>
    </record>

</odoo>
