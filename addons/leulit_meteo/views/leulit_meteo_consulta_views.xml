<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Vista Tree (Lista) -->
    <record id="view_leulit_meteo_consulta_tree" model="ir.ui.view">
        <field name="name">leulit.meteo.consulta.tree</field>
        <field name="model">leulit.meteo.consulta</field>
        <field name="arch" type="xml">
            <tree string="Consultas Meteorológicas">
                <field name="codigo"/>
                <field name="ubicacion"/>
                <field name="fecha_consulta"/>
                <field name="tipo_consulta"/>
                <field name="temperatura"/>
                <field name="descripcion_clima"/>
                <field name="velocidad_viento"/>
                <field name="humedad"/>
                <field name="user_id"/>
            </tree>
        </field>
    </record>
    
    <!-- Vista Form -->
    <record id="view_leulit_meteo_consulta_form" model="ir.ui.view">
        <field name="name">leulit.meteo.consulta.form</field>
        <field name="model">leulit.meteo.consulta</field>
        <field name="arch" type="xml">
            <form string="Consulta Meteorológica">
                <header>
                    <button name="action_consultar_clima_actual" 
                            string="Consultar Clima Actual" 
                            type="object" 
                            class="oe_highlight"
                            icon="fa-cloud-download"
                            attrs="{'invisible': [('fuente_datos', '!=', 'openmeteo')]}"/>
                    <button name="action_consultar_pronostico" 
                            string="Obtener Pronóstico" 
                            type="object" 
                            class="oe_highlight"
                            icon="fa-calendar"
                            attrs="{'invisible': [('fuente_datos', '!=', 'openmeteo')]}"/>
                    <button name="action_consultar_windy" 
                            string="Consultar Windy" 
                            type="object" 
                            class="oe_highlight"
                            icon="fa-wind"
                            attrs="{'invisible': [('fuente_datos', '!=', 'windy')]}"/>
                    <button name="action_cargar_ruta_template" 
                            string="Cargar Ruta" 
                            type="object" 
                            icon="fa-download"
                            attrs="{'invisible': ['|', ('es_polilinea', '=', False), ('ruta_template_id', '=', False)]}"/>
                    <button name="action_guardar_como_template" 
                            string="Guardar como Plantilla" 
                            type="object" 
                            icon="fa-save"
                            attrs="{'invisible': ['|', ('es_polilinea', '=', False), ('numero_puntos', '=', 0)]}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="codigo" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group name="ubicacion" string="Ubicación">
                            <field name="ubicacion"/>
                            <field name="fuente_datos" widget="radio"/>
                            <field name="tipo_consulta"/>
                            <field name="es_polilinea"/>
                            <field name="ruta_template_id" 
                                   attrs="{'invisible': [('es_polilinea', '=', False)]}"/>
                            <field name="numero_puntos" 
                                   attrs="{'invisible': [('es_polilinea', '=', False)]}"/>
                        </group>
                        <group name="coordenadas" string="Coordenadas" 
                               attrs="{'invisible': [('es_polilinea', '=', True)]}">
                            <field name="latitud"/>
                            <field name="longitud"/>
                        </group>
                        <group name="metadata" string="Información">
                            <field name="fecha_consulta"/>
                            <field name="user_id"/>
                            <field name="vuelo_id" attrs="{'invisible': [('vuelo_id', '=', False)]}"/>
                            <field name="active"/>
                        </group>
                    </group>
                    
                    <!-- Resumen de condiciones de la ruta -->
                    <group string="Resumen de Condiciones" 
                           attrs="{'invisible': ['|', ('es_polilinea', '=', False), ('numero_puntos', '=', 0)]}">
                        <group>
                            <field name="temperatura_min" widget="float"/>
                            <field name="temperatura_max" widget="float"/>
                        </group>
                        <group>
                            <field name="viento_max" widget="float"/>
                            <field name="condiciones_criticas" 
                                   widget="boolean"
                                   string="⚠️ Condiciones Críticas"/>
                        </group>
                    </group>
                    
                    <!-- Widget de Mapa -->
                    <group string="Mapa Interactivo">
                        <field name="puntos_geojson" widget="meteo_map" nolabel="1"/>
                    </group>
                    
                    <notebook>
                        <page string="Mapa Windy Visual" name="windy_map" 
                              attrs="{'invisible': [('fuente_datos', '!=', 'windy')]}">
                            <div class="alert alert-info" role="alert">
                                <strong>Mapa Interactivo de Windy:</strong> Visualiza condiciones meteorológicas en tiempo real.
                                Usa los controles del mapa para cambiar capas (viento, temperatura, nubes, etc.)
                            </div>
                            <div class="o_windy_embed_container" style="width: 100%; height: 600px; border: 2px solid #ddd; border-radius: 8px; overflow: hidden;">
                                <iframe 
                                    t-att-src="record.get_windy_embed_url()"
                                    width="100%" 
                                    height="100%" 
                                    frameborder="0"
                                    style="border: none;">
                                </iframe>
                            </div>
                        </page>
                        
                        <page string="Datos Actuales" name="actual" attrs="{'invisible': [('tipo_consulta', '=', 'pronostico')]}">
                            <group>
                                <group name="temperatura" string="Temperatura">
                                    <field name="temperatura" widget="float"/>
                                    <field name="sensacion_termica" widget="float"/>
                                    <field name="humedad" widget="float"/>
                                </group>
                                <group name="condiciones" string="Condiciones">
                                    <field name="descripcion_clima"/>
                                    <field name="codigo_clima"/>
                                    <field name="cobertura_nubes" widget="float"/>
                                    <field name="precipitacion" widget="float"/>
                                </group>
                            </group>
                            <group>
                                <group name="viento" string="Viento">
                                    <field name="velocidad_viento" widget="float"/>
                                    <field name="direccion_viento" widget="float"/>
                                    <field name="rachas_viento" widget="float"/>
                                </grouPuntos de Ruta" name="puntos_ruta" attrs="{'invisible': [('es_polilinea', '=', False)]}">
                            <field name="puntos_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="secuencia" widget="handle"/>
                                    <field name="nombre"/>
                                    <field name="latitud"/>
                                    <field name="longitud"/>
                                    <field name="altitud" optional="hide"/>
                                    <field name="temperatura" readonly="1"/>
                                    <field name="humedad" readonly="1"/>
                                    <field name="velocidad_viento" readonly="1"/>
                                    <field name="direccion_viento" readonly="1" optional="hide"/>
                                    <field name="cobertura_nubes" readonly="1" optional="hide"/>
                                    <field name="precipitacion" readonly="1" optional="hide"/>
                                </tree>
                                <form>
                                    <group>
                                        <group name="identificacion" string="Identificación">
                                            <field name="secuencia"/>
                                            <field name="nombre"/>
                                        </group>
                                        <group name="coordenadas" string="Coordenadas">
                                            <field name="latitud"/>
                                            <field name="longitud"/>
                                            <field name="altitud"/>
                                        </group>
                                    </group>
                                    <group string="Datos Meteorológicos">
                                        <group name="temperatura">
                                            <field name="temperatura"/>
                                            <field name="humedad"/>
                                            <field name="presion"/>
                                        </group>
                                        <group name="viento">
                                            <field name="velocidad_viento"/>
                                            <field name="direccion_viento"/>
                                            <field name="rachas_viento"/>
                                        </group>
                                        <group name="condiciones">
                                            <field name="cobertura_nubes"/>
                                            <field name="precipitacion"/>
                                            <field name="visibilidad"/>
                                        </group>
                                    </group>
                                    <group string="Datos Completos">
                                        <field name="datos_json" widget="ace" options="{'mode': 'json'}"/>
                                    </group>
                                    <group>
                                        <field name="notas" placeholder="Notas sobre este punto..."/>
                                    </group>
                                </form>
                            </field>
                        </page>
                        
                        <page string="p>
                            </group>
                        </page>
                        
                        <page string="Pronóstico" name="pronostico" attrs="{'invisible': [('tipo_consulta', '=', 'actual')]}">
                            <group>
                                <field name="datos_pronostico" widget="ace" options="{'mode': 'json'}"/>
                            </group>
                        </page>
                        
                        <page string="Notas" name="notas">
                            <field name="notas" placeholder="Notas adicionales sobre la consulta meteorológica..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    
    <!-- Vista Search -->
    <record id="view_leulit_meteo_consulta_search" model="ir.ui.view">
        <field name="name">leulit.meteo.consulta.search</field>
        <field name="model">leulit.meteo.consulta</field>
        <field name="arch" type="xml">
            <search string="Buscar Consultas Meteorológicas">
                <field name="codigo"/>
                <field name="ubicacion"/>
                <field name="user_id"/>
                <field name="fecha_consulta"/>
                
                <filter string="Clima Actual" name="filter_actual" 
                        domain="[('tipo_consulta', '=', 'actual')]"/>
                <filter string="Pronóstico" name="filter_pronostico" 
                        domain="[('tipo_consulta', '=', 'pronostico')]"/>
                
                <separator/>
                <filter string="Hoy" name="filter_today" 
                        domain="[('fecha_consulta', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))), 
                                 ('fecha_consulta', '&lt;=', datetime.datetime.combine(context_today(), datetime.time(23,59,59)))]"/>
                <filter string="Esta Semana" name="filter_this_week" 
                        domain="[('fecha_consulta', '&gt;=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d')),
                                 ('fecha_consulta', '&lt;=', (context_today() + datetime.timedelta(days=6-context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                
                <separator/>
                <filter string="Mis Consultas" name="filter_my_consultas" 
                        domain="[('user_id', '=', uid)]"/>
                
                <separator/>
                <filter string="Archivado" name="inactive" domain="[('active', '=', False)]"/>
                
                <group expand="0" string="Agrupar por">
                    <filter string="Ubicación" name="group_ubicacion" context="{'group_by': 'ubicacion'}"/>
                    <filter string="Tipo" name="group_tipo" context="{'group_by': 'tipo_consulta'}"/>
                    <filter string="Usuario" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Fecha" name="group_fecha" context="{'group_by': 'fecha_consulta'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Acción de Ventana -->
    <record id="action_leulit_meteo_consulta" model="ir.actions.act_window">
        <field name="name">Consultas Meteorológicas</field>
        <field name="res_model">leulit.meteo.consulta</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_my_consultas': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear una nueva consulta meteorológica
            </p>
            <p>
                Registre consultas meteorológicas para diferentes ubicaciones.
                Puede obtener datos en tiempo real desde Open-Meteo API.
            </p>
        </field>
    </record>
    
</odoo>
