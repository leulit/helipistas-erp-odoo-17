<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Aeródromos / helipuertos de referencia.
        - tiene_metar_propio = True  -> se consulta el propio OACI.
        - tiene_metar_propio = False -> se usa el ref_icao para METAR/TAF.
        SIGMET siempre se pide por la FIR del registro.
        Esta lista es la mínima operativa; el administrador la completa
        desde el menú "Meteorología -> Aeródromos de Referencia".
    -->

