<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Añade el campo is_lost al formulario de etapas CRM -->
    <record id="crm_stage_form_view_is_lost" model="ir.ui.view">
        <field name="name">crm.stage.form.is_lost</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_form"/>
        <field name="arch" type="xml">
            <field name="is_won" position="after">
                <field name="is_lost"/>
            </field>
        </field>
    </record>

</odoo>
