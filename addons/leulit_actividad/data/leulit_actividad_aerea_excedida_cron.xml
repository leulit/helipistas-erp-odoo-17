<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="cron_check_actividad_aerea_excedida" model="ir.cron">
            <field name="name">LEULIT - Aviso actividad aérea excedida</field>
            <field name="model_id" ref="model_leulit_actividad_aerea"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_actividad_aerea_excedida()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <record id="email_template_actividad_aerea_excedida" model="mail.template">
            <field name="name">Notificación Actividad Aérea Excedida</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="subject">Aviso: límite de actividad aérea superado</field>
            <field name="email_from">erp@helipistas.com</field>
            <field name="email_to">{{ ctx.get('mail_to') }}</field>
            <field name="email_cc">ops@helipistas.com</field>
            <field name="body_html" type="html">
                <div>
                    <p>Se ha detectado que se ha superado el tiempo máximo de actividad aérea permitido.</p>

                    <p>
                        Debes registrar una <strong>ocurrencia en el ERP</strong>,
                        indicando el motivo por el cual se ha superado el límite de actividad.
                    </p>

                    <t t-foreach="ctx.get('dias', [])" t-as="dia">
                        <div style="margin-bottom: 20px;">
                            <p style="background-color: #f2f2f2; padding: 5px;">
                                <strong>Fecha: <t t-out="dia.get('fecha')"/></strong><br/>
                                Tiempo de actividad: <t t-out="'%.2f' % dia.get('tiempo')"/> h
                                — Tiempo máximo permitido: <t t-out="'%.2f' % dia.get('max_duracion')"/> h
                                — Exceso: <strong><t t-out="'%.2f' % dia.get('exceso')"/> h</strong>
                            </p>

                            <p>Detalle de la actividad de ese día:</p>
                            <table style="width:100%; border-collapse: collapse;" border="1" cellpadding="4">
                                <thead>
                                    <tr>
                                        <th>Tipo actividad</th>
                                        <th>Descripción</th>
                                        <th>Inicio</th>
                                        <th>Fin</th>
                                        <th>Tiempo (h)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="dia.get('lineas', [])" t-as="linea">
                                        <tr>
                                            <td><t t-out="linea.get('tipo_actividad')"/></td>
                                            <td><t t-out="linea.get('descripcion')"/></td>
                                            <td><t t-out="linea.get('inicio')"/></td>
                                            <td><t t-out="linea.get('fin')"/></td>
                                            <td><t t-out="'%.2f' % linea.get('tiempo')"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>

                    <p t-if="not ctx.get('dias')">
                        <em>No hay actividad excedida para reportar.</em>
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>
