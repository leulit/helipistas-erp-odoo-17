<?xml version="1.0" encoding="UTF-8"?>
<openerp>
    <data>

        <record id="leulit_20260401_1013_tree" model="ir.ui.view">
            <field name="name">Árbol anotaciones technical log</field>
            <field name="model">leulit.anotacion_technical_log</field>
            <field name="inherit_id" ref="leulit_seguridad.leulit_20260401_1013_tree" />
            <field name="arch" type="xml">
                <field name="codigo" position="before">
                    <field name="semaforo_firma" string="Firma" widget="semaforo_char"/>
                </field>
            </field>
        </record>

        <record id="leulit_20260401_1013_form" model="ir.ui.view">
            <field name="name">Documentos firmados anotaciones technical log</field>
            <field name="model">leulit.anotacion_technical_log</field>
            <field name="inherit_id" ref="leulit_seguridad.leulit_20260401_1013_form" />
            <field name="arch" type="xml">
                <xpath expr="//header" position="after">
                    <field name="id" invisible="1"/>
                    <field name="check_firmado" invisible="1"/>
                </xpath>
                <xpath expr="//button[@name='wizard_close']" position="attributes">
                    <attribute name="invisible">estado in ['closed'] and check_firmado</attribute>
                </xpath>
                <xpath expr="//sheet" position="inside">
                    <group string="Documentos firmados">
                        <field name="esignature_docs" colspan="4" nolabel="1" context="{'form_view_ref' : 'leulit_20210112_1138_form'}">
                            <tree>
                                <field name="id"/>
                                <field name="firmado_por" string="Por"/>
                                <field name="name" />
                                <field name="hashcode" /> 
                                <field name="attachment_id"/>
                            </tree>
                        </field>
                    </group>
                </xpath>
            </field>
        </record>


    </data>
</openerp>