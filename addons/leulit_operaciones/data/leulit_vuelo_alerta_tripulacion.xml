<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="leulit_vuelo_alerta_tripulacion" model="mail.template">
            <field name="name">Alerta OPS - Tripulación pendiente de localizar</field>
            <field name="model_id" ref="model_leulit_vuelo"/>
            <field name="email_from">erp@helipistas.com</field>
            <field name="email_to">ops@helipistas.com</field>
            <field name="subject">{{ ctx.get('subject') }}</field>
            <field name="auto_delete" eval="True"/>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; font-size: 14px; color: #333;">

                    <p>Estimado equipo de Operaciones,</p>

                    <p>
                        El siguiente parte de vuelo se encuentra en estado <strong>Post-Vuelo</strong>
                        y la hora de llegada prevista ya ha sido superada en
                        <strong><t t-out="ctx.get('minutos_retraso')"/> minutos</strong>.
                        Es necesario localizar a la tripulación para confirmar su situación
                        y proceder al cierre del parte.
                    </p>

                    <table border="1" cellpadding="8" cellspacing="0"
                           style="border-collapse: collapse; width: 100%; max-width: 600px;">
                        <tr style="background-color: #f2f2f2;">
                            <td><strong>Código de vuelo</strong></td>
                            <td><t t-out="object.codigo"/></td>
                        </tr>
                        <tr>
                            <td><strong>Fecha</strong></td>
                            <td><t t-out="object.fechavuelo"/></td>
                        </tr>
                        <tr style="background-color: #f2f2f2;">
                            <td><strong>Aeronave</strong></td>
                            <td><t t-out="object.helicoptero_id.name"/></td>
                        </tr>
                        <tr>
                            <td><strong>Piloto (PIC)</strong></td>
                            <td><t t-out="object.piloto_id.name"/></td>
                        </tr>
                        <tr style="background-color: #f2f2f2;">
                            <td><strong>Origen</strong></td>
                            <td><t t-out="object.lugarsalida.name"/></td>
                        </tr>
                        <tr>
                            <td><strong>Destino</strong></td>
                            <td><t t-out="object.lugarllegada.name"/></td>
                        </tr>
                        <tr style="background-color: #f2f2f2;">
                            <td><strong>Hora de salida (local)</strong></td>
                            <td><t t-out="object.strhorasalida"/></td>
                        </tr>
                        <tr>
                            <td><strong>Hora de llegada prevista (local)</strong></td>
                            <td><t t-out="ctx.get('hora_llegada_local')"/></td>
                        </tr>
                        <tr style="background-color: #f2f2f2;">
                            <td><strong>Hora de llegada prevista (UTC)</strong></td>
                            <td><t t-out="ctx.get('hora_llegada_utc')"/></td>
                        </tr>
                        <tr style="background-color: #ffe0e0;">
                            <td><strong>Retraso acumulado</strong></td>
                            <td><strong><t t-out="ctx.get('minutos_retraso')"/> minutos</strong></td>
                        </tr>
                    </table>

                    <br/>
                    <p>Por favor, contactad con la tripulación para verificar su estado y actualizar el parte de vuelo.</p>
                    <p style="color: #999; font-size: 12px;">
                        Este mensaje ha sido generado automáticamente por el sistema ERP de Helipistas.
                    </p>

                </div>
            </field>
        </record>

    </data>
</odoo>
