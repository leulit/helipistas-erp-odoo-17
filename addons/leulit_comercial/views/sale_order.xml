<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="sale_order_tree_leulit" model="ir.ui.view">
            <field name="name">view_quotation_tree_with_onboarding_leulit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='company_id']" position="after">
                    <field name="origin" string="Información" optional="show"/>
                </xpath>
            </field>
        </record>

        <record id="sale_order_form_commitment_date_leulit" model="ir.ui.view">
            <field name="name">view_order_form_commitment_date_leulit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//label[@for='commitment_date']" position="attributes">
                    <attribute name="string">Fecha de entrega/servicio</attribute>
                </xpath>
                <xpath expr="//field[@name='commitment_date']" position="attributes">
                    <attribute name="nolabel">1</attribute>
                </xpath>
                <xpath expr="//field[@name='date_order']" position="after">
                    <label for="commitment_date" position="move"/>
                    <field name="commitment_date" position="move"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>